FROM fedora:latest

# Build arguments for flexibility
ARG GO_VERSION=1.26.2
ARG USER_NAME=developer
ARG USER_UID=1000
ARG USER_GID=1000
ARG CACHEBUST=1

# Consolidated Layer: System deps, Go installation, and User setup
# This keeps the base layer small by cleaning up dnf cache and tarballs immediately
RUN dnf -y update && dnf -y install \
    curl tar gzip git gcc glibc-devel make tmux vim-enhanced jq \
    powerline-fonts && \
    dnf clean all && \
    # Install Go
    curl -OL https://go.dev/dl/go${GO_VERSION}.linux-amd64.tar.gz && \
    tar -C /usr/local -xzf go${GO_VERSION}.linux-amd64.tar.gz && \
    rm go${GO_VERSION}.linux-amd64.tar.gz && \
    # Group/User logic: use || echo to handle existing IDs gracefully
    groupadd -g $USER_GID $USER_NAME || echo "Group already exists" && \
    useradd -u $USER_UID -g $USER_GID -m -l $USER_NAME || echo "User already exists" && \
    mkdir -p /home/$USER_NAME/project && \
    chown -R $USER_UID:$USER_GID /home/$USER_NAME

# Set Environment Variables
ENV GOROOT=/usr/local/go
ENV GOPATH=/home/${USER_NAME}/go
ENV PATH=$PATH:$GOROOT/bin:$GOPATH/bin

USER $USER_NAME
WORKDIR /home/$USER_NAME

# Separate layer for dotfiles and plugins to utilize caching for your dev environment
RUN git clone https://github.com/lazyhacker/dotfiles.git /home/$USER_NAME/dotfiles && \
    cd /home/$USER_NAME/dotfiles && \
    if [ -f ./install.sh ]; then \
        chmod +x ./install.sh && ./install.sh; \
    fi && \
    # Setup Vim and Vundle in one go
    mkdir -p /home/$USER_NAME/.vim/bundle && \
    git clone https://github.com/VundleVim/Vundle.vim.git /home/$USER_NAME/.vim/bundle/Vundle.vim && \
    vim -u /home/${USER_NAME}/.vimrc -T dumb -n -i NONE -es \
    -c "silent! PluginInstall" \
    -c "silent! GoInstallBinaries" \
    -c "qall" || true

WORKDIR /home/$USER_NAME/project
CMD ["sleep", "infinity"]
